{
  "name": "lucky-gems-telegram",
  "main": "src/index.ts",
  "compatibility_date": "2025-01-15",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "lucky-gems-db",
      "database_id": "CHANGE_ME_AFTER_DB_CREATE"
    }
  ],
  "r2_buckets": [
    {
      "binding": "ASSETS",
      "bucket_name": "lucky-gems-assets"
    }
  ],
  "vars": {
    "WEBAPP_URL": "https://lucky-gems-telegram.workers.dev"
  }
}
